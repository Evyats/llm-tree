APP_NAME=chat-tree-api
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+psycopg://chat_tree:chat_tree@localhost:5432/chat_tree
OPENAI_MODELS=gpt-5.2,gpt-4o-mini
OPENAI_API_KEY=
FALLBACK_ENABLED=true
OPENAI_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_PER_RUN=true
